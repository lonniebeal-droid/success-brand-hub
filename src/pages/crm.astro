---
const modules = ['Clients','Prospects','Leads','Contacts','Notes','Appointments','Tasks','Follow-ups','Documents','Activity timeline','Status history','Tags'];
---
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><meta name="robots" content="noindex"><title>Success Brand CRM</title><style>:root{font-family:Inter,system-ui;background:#071425;color:#eef6ff}body{margin:0}.wrap{max-width:1120px;margin:auto;padding:38px 20px}.label{color:#62d4ff;font-weight:800}.warning{color:#fbbf24}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:14px}.card{background:#10233d;border:1px solid #284768;border-radius:16px;padding:18px}.muted{color:#9db1c9}.status{display:inline-block;border-radius:999px;padding:5px 10px;background:#17385f;color:#93dcff;font-size:12px}a{color:#7dd3fc}</style></head><body><main class="wrap"><p class="label">SUCCESS BRAND HUB · STAGING</p><h1>CRM operations</h1><p class="warning">Authenticated staging module. Live services are disabled.</p><div class="grid">{modules.map(name=><section class="card"><h2>{name}</h2><p class="muted">Persistent CRM records with search, filters, tags, and activity tracking.</p><span class="status">API ready</span></section>)}</div><p><a href="/callcenter">Call center</a> · <a href="/executive-dashboard">Executive dashboard</a></p></main></body></html>
