<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SuccessBrand Hub</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-black text-white p-8">
    
    <header class="mb-12 border-b border-gray-800 pb-8">
      <h1 class="text-6xl font-black uppercase tracking-tighter">SuccessBrand</h1>
      <p class="text-xl text-gray-400">Broadcast Your Hustle</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="md:col-span-2 bg-blue-600 rounded-3xl p-8 h-80 flex flex-col justify-end hover:scale-[1.01] transition-transform shadow-2xl">
        <span class="text-sm font-bold uppercase tracking-widest opacity-80">Core Tech</span>
        <h2 class="text-5xl font-bold mt-2">AI Voice Agent</h2>
      </div>

      <div class="bg-purple-700 rounded-3xl p-8 h-80 flex flex-col justify-end hover:scale-[1.01] transition-transform shadow-2xl">
        <h2 class="text-3xl font-bold">VR Wellness</h2>
      </div>

      <div class="bg-red-600 rounded-3xl p-8 h-80 flex flex-col justify-end hover:scale-[1.01] transition-transform shadow-2xl">
        <h2 class="text-3xl font-bold">Lock & Hustle</h2>
      </div>
      
      <div class="bg-gray-800 rounded-3xl p-8 h-80 flex flex-col justify-end hover:scale-[1.01] transition-transform shadow-2xl">
        <h2 class="text-3xl font-bold">SuccessBrand Intake</h2>
      </div>
    </div>

  </body>
</html>
