JESSE_ENVIRONMENT=development
JESSE_DATA_PATH=agents/jessie/data/intakes.json
JESSE_LOG_LEVEL=INFO
JESSE_ADMIN_TOKEN=replace-with-admin-token
JESSE_TWILIO_TOKEN=replace-with-twilio-token
JESSE_ELEVENLABS_TOKEN=replace-with-elevenlabs-token
JESSE_N8N_TOKEN=replace-with-n8n-token
JESSE_GOOGLE_TOKEN=replace-with-google-token
JESSE_RATE_LIMIT_PER_KEY=5
JESSE_RATE_LIMIT_PER_IP=5
JESSE_RATE_LIMIT_REQUESTS=5
JESSE_RATE_LIMIT_WINDOW_SECONDS=60
JESSE_INTEGRATION_MODE=mock
JESSE_API_URL=http://127.0.0.1:8000
JESSE_DASHBOARD_TOKEN=replace-with-dashboard-token
JESSE_TWILIO_ENABLED=false
JESSE_ELEVENLABS_ENABLED=false
JESSE_GOOGLE_CALENDAR_ENABLED=false
JESSE_GMAIL_ENABLED=false
JESSE_GOOGLE_SHEETS_ENABLED=false
JESSE_N8N_ENABLED=false
